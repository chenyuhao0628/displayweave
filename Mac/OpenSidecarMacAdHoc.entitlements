<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Development Preview builds have no Team ID. Hardened Runtime otherwise
      rejects the embedded Sparkle framework before main() because two ad-hoc
      signatures cannot satisfy same-team library validation. Production
      Developer ID builds keep using OpenSidecarMac.entitlements instead.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
